#full ASCII table generator in Python
def ascii_table():
    print(f"{'Dec':<5} {'Hex':<5} {'Oct':<5} {'Bin':<10} {'HTML':<8} {'Chr'}")
    print("-" * 60)

    for i in range(128):
        dec = i
        hexa = format(i, '02X')
        octal = format(i, '03o')
        binary = format(i, '08b')   # 8-bit binary
        html = f"&#{i};"

        # Handle non-printable characters
        if i < 32 or i == 127:
            char = "CTRL"
        else:
            char = chr(i)

        print(f"{dec:<5} {hexa:<5} {octal:<5} {binary:<10} {html:<8} {char}")

ascii_table()


